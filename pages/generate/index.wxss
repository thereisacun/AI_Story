/* pages/generate/index.wxss */

.quota-bar {
  text-align: center;
  padding: 16rpx;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.quota-text {
  font-size: 26rpx;
  color: #666;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  min-width: 130rpx;
}

.category-item.active {
  border-color: #3CAB6E;
  background: #e8f5ed;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

.topic-input {
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
}

.input {
  width: 100%;
  padding: 20rpx 0;
  font-size: 30rpx;
}

.generate-btn {
  width: 100%;
  padding: 28rpx;
  background: #3CAB6E;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}

.generate-btn[disabled],
.generate-btn.disabled {
  background: #ccc;
  color: #fff;
}

.generate-btn.loading {
  background: #ff7f50;
}

.error-tip {
  text-align: center;
  padding: 16rpx;
  color: #ff4d4f;
  font-size: 26rpx;
}

.result-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.result-content {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.result-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  white-space: pre-wrap;
}

.view-btn {
  width: 100%;
  padding: 24rpx;
  background: #3CAB6E;
  color: #fff;
  font-size: 30rpx;
  border-radius: 8rpx;
  border: none;
}

.generating-tip {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 26rpx;
}