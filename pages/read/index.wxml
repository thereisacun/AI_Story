<!-- pages/read/index.wxml -->
<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 文章内容 -->
  <view wx:else-if="{{article}}" class="article-content">
    <!-- 标题 -->
    <view class="article-header">
      <text class="article-title">{{article.title}}</text>
      <view class="article-meta">
        <text class="article-words">{{article.words.length}} 个单词</text>
        <text class="article-category">{{article.category}}</text>
      </view>
    </view>

    <!-- 模式切换 -->
    <view class="mode-switch">
      <view
        class="mode-btn {{displayMode === 'mixed' ? 'active' : ''}}"
        bindtap="onModeChange"
        data-mode="mixed"
      >
        中英夹杂
      </view>
      <view
        class="mode-btn {{displayMode === 'cn' ? 'active' : ''}}"
        bindtap="onModeChange"
        data-mode="cn"
      >
        全中文
      </view>
      <view
        class="mode-btn {{displayMode === 'en' ? 'active' : ''}}"
        bindtap="onModeChange"
        data-mode="en"
      >
        全英文
      </view>
    </view>

    <!-- 正文 -->
    <view class="article-body">
      <text class="article-text">{{displayContent}}</text>
    </view>

    <!-- 底部操作栏 -->
    <view class="action-bar">
      <view class="action-btn" bindtap="onFavoriteTap">
        <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
        <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-btn" bindtap="onFinishTap">
        <text class="action-icon">✓</text>
        <text class="action-text">标记读完</text>
      </view>
      <button class="share-btn" open-type="share">
        <text class="action-icon">↗</text>
        <text class="action-text">分享</text>
      </button>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <text>文章不存在</text>
  </view>
</view>