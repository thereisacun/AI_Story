/* pages/index/index.wxss */

.member-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #3CAB6E;
  color: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.member-status {
  font-size: 28rpx;
}

.member-arrow {
  font-size: 36rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  min-width: 140rpx;
}

.category-item.active {
  border-color: #3CAB6E;
  background: #e8f5ed;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333;
}

.generate-btn {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #3CAB6E, #2d8a54);
  border-radius: 12rpx;
  color: #fff;
}

.generate-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.generate-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
}

.generate-arrow {
  font-size: 36rpx;
}

.article-list {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.article-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.article-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.article-card-content {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.article-card-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
  line-height: 1.4;
}

.article-card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.article-card-words {
  font-size: 24rpx;
  color: #999;
}

.article-card-status {
  font-size: 24rpx;
  color: #3CAB6E;
}

.article-card-status.finished {
  color: #52c41a;
}

.article-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-info {
  flex: 1;
}

.article-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.article-meta {
  display: flex;
  gap: 16rpx;
}

.article-words {
  font-size: 24rpx;
  color: #999;
}

.article-status {
  font-size: 24rpx;
  color: #3CAB6E;
}

.article-status.finished {
  color: #52c41a;
}

.article-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.loading, .empty {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}